{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:native": {
      "dependsOn": ["^build:native"],
      "outputs": ["generated/**", "artifacts/**"]
    },
    "build:native:dev": {
      "dependsOn": ["^build:native:dev"],
      "outputs": ["generated/**"]
    },
    "pack": {
      "dependsOn": ["^pack"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "outputs": []
    },
    "e2e": {
      "cache": false,
      "outputs": []
    }
  }
}
