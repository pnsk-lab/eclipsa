{
  "tasks": {
    "dev": "cd example && deno run --watch -A start.ts",
    "build": "cd example && deno run -A build.ts",
    "test:watch": "deno test -A --watch --no-check -- --update"
  },
  "workspace": {
    "members": ["./example", "./packages/eclipsa"]
  },
  "fmt": {
    "semiColons": false,
    "singleQuote": true
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@xely/eclipsa",
    "lib": [
      "deno.window",
      "dom"
    ]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.6",
    "fast-glob": "npm:fast-glob@^3.3.2"
  }
}
