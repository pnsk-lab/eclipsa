{
  "name": "@eclipsa/motion",
  "version": "0.0.0",
  "private": false,
  "homepage": "https://github.com/pnsk-lab/eclipsa",
  "bugs": {
    "url": "https://github.com/pnsk-lab/eclipsa/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnsk-lab/eclipsa.git",
    "directory": "packages/motion"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./mod.ts",
      "import": "./mod.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./mod.d.mts",
        "import": "./mod.mjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "pack": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "test": "vp test --run",
    "test:coverage": "c8 --reporter=lcov --reporter=json-summary --reporter=text bunx vp test --run",
    "typecheck": "bun x tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "eclipsa": "workspace:*",
    "motion-dom": "12.38.0",
    "motion-utils": "12.36.0"
  }
}
