{
  "name": "@eclipsa/content",
  "private": false,
  "homepage": "https://github.com/pnsk-lab/eclipsa",
  "bugs": {
    "url": "https://github.com/pnsk-lab/eclipsa/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnsk-lab/eclipsa.git",
    "directory": "packages/content"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./mod.ts",
      "import": "./mod.ts"
    },
    "./vite": {
      "types": "./vite.ts",
      "import": "./vite.ts"
    },
    "./internal": {
      "types": "./internal.ts",
      "import": "./internal.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./mod.d.mts",
        "import": "./mod.mjs"
      },
      "./vite": {
        "types": "./vite.d.mts",
        "import": "./vite.mjs"
      },
      "./internal": {
        "types": "./internal.d.mts",
        "import": "./internal.mjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "pack": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "test": "vp test --run",
    "typecheck": "bun x tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ox-content/napi": "^0.17.0",
    "eclipsa": "workspace:*",
    "fast-glob": "^3.3.2",
    "shiki": "^4.0.2",
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "vite": "*"
  }
}
