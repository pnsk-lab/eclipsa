{
  "name": "@eclipsa/native",
  "version": "0.0.0",
  "homepage": "https://github.com/pnsk-lab/eclipsa",
  "bugs": {
    "url": "https://github.com/pnsk-lab/eclipsa/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnsk-lab/eclipsa.git",
    "directory": "packages/native"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./mod.ts",
      "import": "./mod.ts"
    },
    "./vite": {
      "types": "./vite.ts",
      "import": "./vite.ts"
    },
    "./jsx-runtime": {
      "types": "./jsx-runtime.ts",
      "import": "./jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./jsx-dev-runtime.ts",
      "import": "./jsx-dev-runtime.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./mod.d.mts",
        "import": "./mod.mjs"
      },
      "./vite": {
        "types": "./vite.d.mts",
        "import": "./vite.mjs"
      },
      "./jsx-runtime": {
        "types": "./jsx-runtime.d.mts",
        "import": "./jsx-runtime.mjs"
      },
      "./jsx-dev-runtime": {
        "types": "./jsx-dev-runtime.d.mts",
        "import": "./jsx-dev-runtime.mjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "pack": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "test": "vp test --run",
    "test:coverage": "c8 --reporter=lcov --reporter=json-summary --reporter=text bunx vp test --run",
    "typecheck": "bun x tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@eclipsa/native-core": "workspace:^",
    "@eclipsa/optimizer": "workspace:^",
    "eclipsa": "workspace:^"
  },
  "peerDependencies": {
    "vite": "*"
  }
}
