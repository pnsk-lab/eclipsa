{
  "name": "eclipsa",
  "version": "0.2.0-alpha.0",
  "license": "MIT",
  "homepage": "https://github.com/pnsk-lab/eclipsa",
  "bugs": {
    "url": "https://github.com/pnsk-lab/eclipsa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnsk-lab/eclipsa.git",
    "directory": "packages/eclipsa"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./mod.ts",
      "import": "./mod.ts"
    },
    "./vite": {
      "types": "./vite/mod.ts",
      "import": "./vite/mod.ts"
    },
    "./jsx-runtime": {
      "types": "./jsx/jsx-runtime.ts",
      "import": "./jsx/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./jsx/jsx-dev-runtime.ts",
      "import": "./jsx/jsx-dev-runtime.ts"
    },
    "./jsx": {
      "types": "./jsx/mod.ts",
      "import": "./jsx/mod.ts"
    },
    "./internal": {
      "types": "./core/internal.ts",
      "import": "./core/internal.ts"
    },
    "./client": {
      "types": "./core/client/mod.ts",
      "import": "./core/client/mod.ts"
    },
    "./dev-client": {
      "types": "./core/dev-client/mod.ts",
      "import": "./core/dev-client/mod.ts"
    },
    "./prod-client": {
      "types": "./core/prod-client/mod.ts",
      "import": "./core/prod-client/mod.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./mod.d.mts",
        "import": "./mod.mjs"
      },
      "./vite": {
        "types": "./vite/mod.d.mts",
        "import": "./vite/mod.mjs"
      },
      "./jsx-runtime": {
        "types": "./jsx/jsx-runtime.d.mts",
        "import": "./jsx/jsx-runtime.mjs"
      },
      "./jsx-dev-runtime": {
        "types": "./jsx/jsx-dev-runtime.d.mts",
        "import": "./jsx/jsx-dev-runtime.mjs"
      },
      "./jsx": {
        "types": "./jsx/mod.d.mts",
        "import": "./jsx/mod.mjs"
      },
      "./internal": {
        "types": "./core/internal.d.mts",
        "import": "./core/internal.mjs"
      },
      "./client": {
        "types": "./core/client/mod.d.mts",
        "import": "./core/client/mod.mjs"
      },
      "./dev-client": {
        "types": "./core/dev-client/mod.d.mts",
        "import": "./core/dev-client/mod.mjs"
      },
      "./prod-client": {
        "types": "./core/prod-client/mod.d.mts",
        "import": "./core/prod-client/mod.mjs"
      }
    }
  },
  "napi": {
    "binaryName": "eclipsa",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "wasm32-wasip1-threads"
    ]
  },
  "scripts": {
    "artifacts": "bunx @napi-rs/cli artifacts --package-json-path ./package.json --output-dir ./compiler/native/generated --npm-dir ./npm --build-output-dir ./artifacts",
    "build": "bun run build:js && bun run build:native",
    "build:js": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "build:native:dev": "node -e \"require('node:fs').rmSync('./compiler/native/generated', { recursive: true, force: true })\" && bunx @napi-rs/cli build --platform --manifest-path ./compiler/rust/Cargo.toml --package-json-path ./package.json --target-dir ./compiler/rust/target --output-dir ./compiler/native/generated --js-package-name eclipsa",
    "build:native": "node -e \"require('node:fs').rmSync('./compiler/native/generated', { recursive: true, force: true })\" && bunx @napi-rs/cli build --platform --release --manifest-path ./compiler/rust/Cargo.toml --package-json-path ./package.json --target-dir ./compiler/rust/target --output-dir ./compiler/native/generated --js-package-name eclipsa",
    "create:npm-dirs": "node -e \"require('node:fs').rmSync('./npm', { recursive: true, force: true })\" && bunx @napi-rs/cli create-npm-dirs --package-json-path ./package.json --npm-dir ./npm",
    "pack": "bun run build",
    "prepublishOnly": "bun ./scripts/sync-package-manifest.ts publish && bunx @napi-rs/cli pre-publish -t npm --package-json-path ./package.json --npm-dir ./npm",
    "restore:manifest": "bun ./scripts/sync-package-manifest.ts dev",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "version:napi": "bunx @napi-rs/cli version --package-json-path ./package.json --npm-dir ./npm",
    "test": "bun run build:native:dev && vp test --run"
  },
  "dependencies": {
    "@napi-rs/wasm-runtime": "^1.1.1",
    "fast-glob": "^3.3.2",
    "hono": "^4.6.4"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@typescript/native-preview": "^7.0.0-dev.20260310.1"
  },
  "peerDependencies": {
    "vite": "*"
  }
}
