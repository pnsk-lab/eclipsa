{
  "name": "eclipsa",
  "version": "0.2.0-alpha.0",
  "license": "none",
  "homepage": "https://github.com/pnsk-lab/eclipsa",
  "bugs": {
    "url": "https://github.com/pnsk-lab/eclipsa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnsk-lab/eclipsa.git",
    "directory": "packages/eclipsa"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./mod.ts",
      "import": "./mod.ts"
    },
    "./vite": {
      "types": "./vite/mod.ts",
      "import": "./vite/mod.ts"
    },
    "./jsx-runtime": {
      "types": "./jsx/jsx-runtime.ts",
      "import": "./jsx/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./jsx/jsx-dev-runtime.ts",
      "import": "./jsx/jsx-dev-runtime.ts"
    },
    "./jsx": {
      "types": "./jsx/mod.ts",
      "import": "./jsx/mod.ts"
    },
    "./internal": {
      "types": "./core/internal.ts",
      "import": "./core/internal.ts"
    },
    "./client": {
      "types": "./core/client/mod.ts",
      "import": "./core/client/mod.ts"
    },
    "./dev-client": {
      "types": "./core/dev-client/mod.ts",
      "import": "./core/dev-client/mod.ts"
    },
    "./prod-client": {
      "types": "./core/prod-client/mod.ts",
      "import": "./core/prod-client/mod.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./mod.d.mts",
        "import": "./mod.mjs"
      },
      "./vite": {
        "types": "./vite/mod.d.mts",
        "import": "./vite/mod.mjs"
      },
      "./jsx-runtime": {
        "types": "./jsx/jsx-runtime.d.mts",
        "import": "./jsx/jsx-runtime.mjs"
      },
      "./jsx-dev-runtime": {
        "types": "./jsx/jsx-dev-runtime.d.mts",
        "import": "./jsx/jsx-dev-runtime.mjs"
      },
      "./jsx": {
        "types": "./jsx/mod.d.mts",
        "import": "./jsx/mod.mjs"
      },
      "./internal": {
        "types": "./core/internal.d.mts",
        "import": "./core/internal.mjs"
      },
      "./client": {
        "types": "./core/client/mod.d.mts",
        "import": "./core/client/mod.mjs"
      },
      "./dev-client": {
        "types": "./core/dev-client/mod.d.mts",
        "import": "./core/dev-client/mod.mjs"
      },
      "./prod-client": {
        "types": "./core/prod-client/mod.d.mts",
        "import": "./core/prod-client/mod.mjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "pack": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vp test --run"
  },
  "dependencies": {
    "@babel/core": "^7.25.8",
    "@babel/plugin-syntax-jsx": "^7.25.7",
    "@babel/plugin-transform-react-jsx": "^7.25.7",
    "@babel/traverse": "^7.25.7",
    "@babel/types": "^7.25.8",
    "babel-plugin-jsx-dom-expressions": "^0.39.2",
    "fast-glob": "^3.3.2",
    "hono": "^4.6.4"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.20.6",
    "@typescript/native-preview": "^7.0.0-dev.20260310.1"
  },
  "peerDependencies": {
    "vite": "*"
  }
}
