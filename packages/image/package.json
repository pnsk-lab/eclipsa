{
  "name": "@eclipsa/image",
  "private": false,
  "version": "0.0.0",
  "homepage": "https://github.com/pnsk-lab/eclipsa",
  "bugs": {
    "url": "https://github.com/pnsk-lab/eclipsa/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnsk-lab/eclipsa.git",
    "directory": "packages/image"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./mod.ts",
      "import": "./mod.ts"
    },
    "./client": {
      "types": "./client.d.ts",
      "import": "./client.ts"
    },
    "./vite": {
      "types": "./vite.ts",
      "import": "./vite.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./mod.d.mts",
        "import": "./mod.mjs"
      },
      "./client": {
        "types": "./client.d.ts",
        "import": "./client.mjs"
      },
      "./vite": {
        "types": "./vite.d.mts",
        "import": "./vite.mjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "pack": "vp pack && bun ../../scripts/release/write-dist-package-json.ts",
    "test": "vp test --run",
    "typecheck": "bun x tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "eclipsa": "workspace:*",
    "sharp": "^0.34.5"
  },
  "peerDependencies": {
    "vite": "*"
  }
}
