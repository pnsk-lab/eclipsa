{
  "name": "@eclipsa/native-swiftui",
  "version": "0.0.0",
  "homepage": "https://github.com/pnsk-lab/eclipsa",
  "bugs": {
    "url": "https://github.com/pnsk-lab/eclipsa/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnsk-lab/eclipsa.git",
    "directory": "packages/native-swiftui"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./mod.ts",
      "import": "./mod.ts"
    },
    "./common": {
      "types": "./common.tsx",
      "import": "./common.tsx"
    },
    "./vite": {
      "types": "./vite.ts",
      "import": "./vite.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./mod.d.mts",
        "import": "./mod.mjs"
      },
      "./common": {
        "types": "./common.d.mts",
        "import": "./common.mjs"
      },
      "./vite": {
        "types": "./vite.d.mts",
        "import": "./vite.mjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack && bun ../../scripts/native/prepare-native-dist.ts",
    "host:app": "swift run --package-path ./macos-swiftui EclipsaNativeMacOS",
    "host:build": "swift build --package-path ./macos-swiftui",
    "host:smoke": "swift run --quiet --package-path ./macos-swiftui EclipsaNativeSmoke",
    "pack": "vp pack && bun ../../scripts/native/prepare-native-dist.ts",
    "test": "vp test --run",
    "test:coverage": "c8 --reporter=lcov --reporter=json-summary --reporter=text bunx vp test --run",
    "typecheck": "bun x tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@eclipsa/native": "workspace:^",
    "@eclipsa/native-core": "workspace:^"
  },
  "eclipsaNative": {
    "bundleDir": "host",
    "targets": [
      {
        "id": "darwin-arm64",
        "os": "darwin",
        "arch": "arm64",
        "entrypoint": "binaries/darwin-arm64/EclipsaNativeMacOS",
        "files": [
          {
            "source": "artifacts/darwin-arm64/EclipsaNativeMacOS",
            "destination": "binaries/darwin-arm64/EclipsaNativeMacOS",
            "executable": true
          }
        ]
      },
      {
        "id": "darwin-x64",
        "os": "darwin",
        "arch": "x64",
        "entrypoint": "binaries/darwin-x64/EclipsaNativeMacOS",
        "files": [
          {
            "source": "artifacts/darwin-x64/EclipsaNativeMacOS",
            "destination": "binaries/darwin-x64/EclipsaNativeMacOS",
            "executable": true
          }
        ]
      }
    ]
  }
}
