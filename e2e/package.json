{
  "name": "@eclipsa/e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "e2e": "bun run --cwd ../packages/optimizer build:native:dev && bun ./scripts/run-playwright.ts",
    "e2e:headed": "bun run --cwd ../packages/optimizer build:native:dev && bun ./scripts/run-playwright.ts --headed",
    "e2e:ui": "bun run --cwd ../packages/optimizer build:native:dev && bun ./scripts/run-playwright.ts --ui",
    "build": "vp build",
    "dev": "vp dev",
    "start": "bun dist/server/index.mjs",
    "test": "bun test ./scripts/*.test.ts",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@eclipsa/content": "workspace:*",
    "@eclipsa/image": "workspace:*",
    "@eclipsa/motion": "workspace:*",
    "@eclipsa/react": "workspace:*",
    "@eclipsa/vue": "workspace:*",
    "eclipsa": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vue": "^3.5.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@typescript/native-preview": "^7.0.0-dev.20260310.1",
    "hono": "^4.10.2",
    "mitata": "^1.0.34"
  }
}
