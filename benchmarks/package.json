{
  "name": "benchmarks-workspace",
  "private": true,
  "workspaces": [
    "ssr",
    "client"
  ],
  "scripts": {
    "ssr:build": "bun run --cwd ssr build",
    "ssr:bench:bun": "bun run --cwd ssr bench:bun",
    "ssr:bench:node": "bun run --cwd ssr bench:node",
    "ssr:bench:deno": "bun run --cwd ssr bench:deno",
    "ssr:test": "bun run --cwd ssr test",
    "client:bench": "bun run --cwd client bench",
    "client:test": "bun run --cwd client test"
  },
  "packageManager": "bun@1.3.11"
}
